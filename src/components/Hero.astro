---
// src/components/Hero.astro
// ──────────────────────────────────────────────────────────────
// Full-viewport opening section.
// Background: layered CSS radial-gradients simulating baked crust.
// Decorative: large italic display type, SVG baguette silhouette.
// ──────────────────────────────────────────────────────────────
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-end overflow-hidden"
  aria-label="ヒーローセクション"
>

  <!-- ── Layered CSS gradient background ──────────────────── -->
  <div class="hero-bg absolute inset-0" aria-hidden="true"></div>

  <!-- ── Grain texture overlay ────────────────────────────── -->
  <div class="hero-grain absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <!-- ── Large decorative type in background ──────────────── -->
  <div
    class="absolute inset-0 flex items-center justify-end pr-8 overflow-hidden pointer-events-none"
    aria-hidden="true"
  >
    <span
      class="
        font-display italic font-black
        text-[clamp(12rem,28vw,26rem)]
        text-wheat-DEFAULT/[0.04]
        leading-none tracking-tighter select-none
        translate-x-[8%]
      "
    >
      Pain
    </span>
  </div>

  <!-- ── Decorative SVG baguette ──────────────────────────── -->
  <div
    class="
      absolute right-0 top-1/2 -translate-y-1/2
      w-[min(52vw,680px)] opacity-[0.13]
      pointer-events-none hidden lg:block
    "
    aria-hidden="true"
  >
    <svg viewBox="0 0 680 560" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Body -->
      <ellipse cx="340" cy="280" rx="295" ry="124" fill="#f5edd8"/>
      <ellipse cx="340" cy="280" rx="290" ry="119" fill="none" stroke="#f5edd8" stroke-width="1.5" opacity="0.4"/>
      <!-- Score cuts -->
      <line x1="195" y1="178" x2="240" y2="382" stroke="#f5edd8" stroke-width="3.5" stroke-linecap="round" opacity="0.6"/>
      <line x1="265" y1="163" x2="310" y2="397" stroke="#f5edd8" stroke-width="3.5" stroke-linecap="round" opacity="0.6"/>
      <line x1="335" y1="158" x2="380" y2="402" stroke="#f5edd8" stroke-width="3.5" stroke-linecap="round" opacity="0.6"/>
      <line x1="405" y1="163" x2="448" y2="397" stroke="#f5edd8" stroke-width="3.5" stroke-linecap="round" opacity="0.6"/>
      <line x1="472" y1="178" x2="510" y2="382" stroke="#f5edd8" stroke-width="3.5" stroke-linecap="round" opacity="0.6"/>
      <!-- Highlight -->
      <ellipse cx="340" cy="228" rx="250" ry="45" fill="#f5edd8" opacity="0.06"/>
    </svg>
  </div>

  <!-- ── Main copy ─────────────────────────────────────────── -->
  <div class="relative z-10 section-inner pb-20 md:pb-28">

    <!-- Eyebrow -->
    <p class="eyebrow text-amber-brand mb-5 reveal">
      Artisan Boulangerie — Kanazawa, Ishikawa — Est. 2014
    </p>

    <!-- Headline -->
    <h1
      class="
        font-display italic font-black
        text-display-xl text-wheat-DEFAULT
        leading-[0.92] tracking-[-0.03em]
        max-w-[700px]
        reveal reveal-delay-1
      "
    >
      Fired<br/>
      with <em class="not-italic text-amber-brand">Soul.</em>
    </h1>

    <!-- Subheadline (Japanese) -->
    <p
      class="
        font-serif text-[clamp(0.95rem,2vw,1.2rem)] font-light
        text-wheat-DEFAULT/70 leading-[1.95]
        mt-6 max-w-[460px]
        reveal reveal-delay-2
      "
    >
      自家製酵母、24時間低温発酵、薪窯焼成。<br/>
      本物のパンに、近道はない。<br/>
      金沢・東山の石畳の先に、その窯があります。
    </p>

    <!-- CTA row -->
    <div class="flex flex-wrap items-center gap-4 mt-10 reveal reveal-delay-3">
      <a
        href="#products"
        class="
          inline-flex items-center gap-3
          font-sans text-[0.78rem] uppercase tracking-[0.2em]
          bg-amber-brand text-kiln-800
          px-7 py-3.5
          hover:bg-amber-600 transition-colors duration-300
        "
      >
        <span>今日のパン</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="8" x2="13" y2="8"/>
          <polyline points="9 4 13 8 9 12"/>
        </svg>
      </a>
      <a
        href="#concept"
        class="
          inline-flex items-center gap-2
          font-sans text-[0.75rem] uppercase tracking-[0.18em]
          text-wheat-DEFAULT/60 border-b border-wheat-DEFAULT/20
          pb-0.5
          hover:text-amber-brand hover:border-amber-brand
          transition-colors duration-300
        "
      >
        私たちのこだわり
      </a>
    </div>

  </div><!-- /copy -->

  <!-- ── Scroll indicator ──────────────────────────────────── -->
  <div
    class="
      absolute bottom-8 left-1/2 -translate-x-1/2
      flex flex-col items-center gap-2
      text-wheat-DEFAULT/30
    "
    aria-hidden="true"
  >
    <span class="font-sans text-[0.58rem] tracking-[0.25em] uppercase">Scroll</span>
    <div class="w-px h-9 bg-gradient-to-b from-amber-brand to-transparent animate-scroll-bounce"></div>
  </div>

</section>

<style>
  /* ── Bread-warm gradient background ───────────────── */
  .hero-bg {
    background:
      linear-gradient(
        155deg,
        rgba(28, 16, 8, 0.08)  0%,
        rgba(28, 16, 8, 0.52)  55%,
        rgba(28, 16, 8, 0.92)  100%
      ),
      radial-gradient(ellipse at 28% 38%, #a0612a 0%, transparent 48%),
      radial-gradient(ellipse at 68% 58%, #7a3f20 0%, transparent 44%),
      radial-gradient(ellipse at 52% 25%, #c87c3a 0%, transparent 38%),
      radial-gradient(ellipse at 18% 68%, #6b2e1e 0%, transparent 32%),
      radial-gradient(ellipse at 82% 22%, #b06828 0%, transparent 36%),
      #3a1e0c;
  }

  /* ── Noise grain ───────────────────────────────────── */
  .hero-grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.07'/%3E%3C/svg%3E");
    opacity: 0.4;
  }
</style>
