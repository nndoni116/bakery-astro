---
import { client } from "../lib/microcms";
import type { News } from "../lib/microcms";

const response = await client.get({ endpoint: "news" });
const newsList = response.contents;
---

<section class="max-w-3xl mx-auto px-6 py-16 text-slate-800">
  {/* 見出し */}
  <div class="text-center mb-12">
    <h2 class="text-3xl font-bold tracking-widest relative inline-block pb-4">
      お知らせ
      <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-10 h-1 md:h-0.5 bg-amber-800"></span>
    </h2>
  </div>

  <ul class="divide-y divide-slate-100">
    {newsList.map((news: News) => (
      <li class="py-8 group">
        <div class="flex flex-col md:flex-row md:items-baseline md:gap-8">
          {/* 日付 */}
          <time class="text-sm font-medium text-slate-400 mb-2 md:mb-0 md:min-w-[120px]">
            {new Date(news.publishedAt).toLocaleDateString('ja-JP')}
          </time>

          <div class="flex-1">
            {/* タイトル */}
            <h3 class="text-xl font-semibold mb-3 group-hover:text-amber-800 transition-colors">
              {news.title}
            </h3>
            
            {/* 本文 (proseクラスを使ってmicroCMSのHTMLを綺麗に整える) */}
            <div 
              class="prose prose-slate prose-sm max-w-none text-slate-600 leading-relaxed"
              set:html={news.content} 
            />
          </div>
        </div>
      </li>
    ))}
  </ul>
</section>

<style>
  .news-section {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
  /* ここにお店の雰囲気に合わせたCSSを書く */
</style>