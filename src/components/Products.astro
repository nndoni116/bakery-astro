const delays = ['', 'fade-in-delay-1', 'fade-in-delay-2', 'fade-in-delay-3'];
---

<section id="products">
  <div class="section-inner">

    <!-- Section header -->
    <div class="products-header">
      <div>
        <span class="section-label fade-in">— Our Breads</span>
        <h2 class="section-title fade-in">Signature<br/>Collection</h2>
        <p class="section-title-jp fade-in">定番のパンたち</p>
        <div class="divider fade-in"></div>
      </div>
      <p class="products-note fade-in">
        仕入れや発酵の状態によって、<br/>品揃えは日々変わります。<br/>お電話でご確認ください。
      </p>
    </div>

    <!-- Product card grid -->
    <div class="products-grid">
      {products.map((p, i) => (
        <ProductCard {...p} delay={delays[i]} />
      ))}
    </div>

  </div>
</section>

<style>
  #products { background: var(--color-wheat); }

  .products-header {
    display:         flex;
    justify-content: space-between;
    align-items:     flex-end;
    margin-bottom:   64px;
    flex-wrap:       wrap;
    gap:             24px;
  }
  .products-note {
    font-size:   0.82rem;
    color:       var(--color-ash);
    max-width:   240px;
    line-height: 1.9;
    text-align:  right;
  }
  .products-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap:                   24px;
  }

  @media (max-width: 768px) {
    .products-note { text-align: left; }
  }
</style>
