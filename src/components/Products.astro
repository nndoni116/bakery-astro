const delays = ['', 'reveal-delay-1', 'reveal-delay-2', 'reveal-delay-3'];
const schedDelays = ['', 'reveal-delay-1', 'reveal-delay-2', 'reveal-delay-1', 'reveal-delay-2', 'reveal-delay-3'];
---

<!-- ════ Products ════════════════════════════════════════════ -->
<section
  id="products"
  class="section-pad bg-wheat-DEFAULT"
  aria-labelledby="products-heading"
>
  <div class="section-inner">

    <!-- Header row -->
    <div class="flex flex-wrap justify-between items-end gap-6 mb-14">
      <div class="reveal">
        <span class="eyebrow text-amber-brand">— Our Breads</span>
        <span class="section-rule"></span>
        <h2
          id="products-heading"
          class="font-display italic text-display-md text-crust-DEFAULT mt-1 leading-tight"
        >
          Signature<br/>Collection
        </h2>
        <p class="font-sans text-[0.8rem] tracking-[0.1em] text-smoke-light uppercase mt-1">
          定番のパンたち
        </p>
      </div>
      <p class="reveal reveal-delay-2 font-sans text-body-sm text-smoke-light max-w-[240px] text-right leading-relaxed">
        品揃えは仕入れや発酵状況によって<br/>毎日変わります。<br/>お電話でご確認ください。
      </p>
    </div>

    <!-- Product card grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
      {products.map((p, i) => (
        <ProductCard {...p} delay={delays[i]} />
      ))}
    </div>

  </div>
</section>

<!-- ════ Schedule ════════════════════════════════════════════ -->
<section
  id="schedule"
  class="section-pad bg-kiln-DEFAULT relative overflow-hidden"
  aria-labelledby="schedule-heading"
>
  <!-- Subtle warm glow -->
  <div
    class="absolute bottom-0 left-0 w-[420px] h-[420px] pointer-events-none"
    style="background: radial-gradient(circle at 0% 100%, rgba(107,58,26,0.28) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="section-inner relative z-10">

    <!-- Section heading -->
    <div class="max-w-content mb-14 reveal">
      <span class="eyebrow text-amber-brand">— Baking Schedule</span>
      <span class="section-rule"></span>
      <h2
        id="schedule-heading"
        class="font-display italic text-display-md text-wheat-DEFAULT mt-1 leading-tight"
      >
        When Bread<br/>
        <em class="not-italic text-amber-brand">Comes Alive</em>
      </h2>
      <p class="font-sans text-body-sm text-wheat-DEFAULT/40 mt-2 max-w-narrow">
        パンは生き物です。仕込みから焼成まで、一日の流れをご覧ください。
        焼き上がりの時間を目安にご来店いただくと、最高の状態でお渡しできます。
      </p>
    </div>

    <!-- Timeline -->
    <div class="max-w-[680px] relative">
      <!-- Vertical guide line -->
      <div
        class="absolute left-[72px] top-4 bottom-4 w-px"
        style="background: linear-gradient(to bottom, transparent, var(--c-amber) 10%, var(--c-amber) 90%, transparent);"
        aria-hidden="true"
      ></div>

      {schedule.map((row, i) => (
        <div class={`flex items-start gap-8 py-6 reveal ${schedDelays[i]}`}>
          <!-- Time -->
          <span class="font-display italic text-[1.5rem] text-amber-brand min-w-[72px] text-right pt-0.5 leading-none">
            {row.time}
          </span>
          <!-- Dot -->
          <div
            class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-amber-brand border-2 border-kiln-DEFAULT mt-2 relative -left-1"
            style="box-shadow: 0 0 0 3px rgba(193,127,59,.18);"
            aria-hidden="true"
          ></div>
          <!-- Copy -->
          <div>
            <h3 class="font-serif text-[0.98rem] font-medium text-wheat-DEFAULT leading-snug">
              {row.title}
            </h3>
            <p class="font-sans text-body-sm text-wheat-DEFAULT/42 mt-1.5 leading-[1.78]">
              {row.body}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
