// ── Baking schedule ───────────────────────────────────────────
const schedule = [
  { time: '5:30',  title: '仕込み開始 / 生地の成形',  body: '前日から低温発酵させた生地を窯に入れる準備。職人の手で一つひとつ成形されます。' },
  { time: '6:00',  title: '開店 / 第一陣 バゲット',   body: '窯に火が入り、最初のバゲットが焼き上がります。早起きが報われる、最もクリスピーな時間。' },
  { time: '9:00',  title: 'カンパーニュ・ライ麦パン', body: '大型のハード系が続々と登場。クラストが冷めていく音に耳を澄ませてください。' },
  { time: '11:30', title: '第二陣 バゲット / フーガス', body: '昼食に合わせた追加焼成。数量限定のため、お早めにどうぞ。' },
  { time: '14:00', title: '週替わり特別パン',          body: 'クロワッサン、パン・オ・ノワ、季節のフルーツパンなど。SNSで前日お知らせします。' },
  { time: '17:00', title: '閉店（売り切れ次第終了）',  body: '本日のパンがなくなり次第終了です。明日もまた、焼き立てをお届けします。' },
