---
// src/components/ProductCard.astro
// ──────────────────────────────────────────────────────────────
// Reusable product card. All display data is injected via Props
// so the parent (Products.astro) drives the content.
//
// Props:
//  name       — English product name       e.g. "Baguette"
//  nameJp     — Japanese subtitle          e.g. "バゲット・トラディション"
//  price      — Price string               e.g. "¥340"
//  priceNote  — Optional price qualifier   e.g. "/ 1/2カット ¥580"
//  desc       — Japanese prose description
//  badge      — Optional badge text        e.g. "Signature"
//  svgBg      — Complete <svg> string for the card illustration
//  delay      — Tailwind reveal-delay class e.g. "reveal-delay-2"
// ──────────────────────────────────────────────────────────────
export interface Props {
  name:       string;
  nameJp:     string;
  price:      string;
  priceNote?: string;
  desc:       string;
  badge?:     string;
  svgBg:      string;
  delay?:     string;
}

const {
  name,
  nameJp,
  price,
  priceNote,
  desc,
  badge,
  svgBg,
  delay = '',
} = Astro.props;
---

<article class={`product-card group reveal ${delay}`}>

  <!-- ── Illustration area ────────────────────────────────── -->
  <div class="product-img overflow-hidden relative bg-kiln-800" style="height: 268px;">
    <!-- SVG illustration injected by parent -->
    <div
      class="w-full h-full transition-transform duration-700 ease-out-expo group-hover:scale-[1.05]"
      aria-hidden="true"
    >
      <Fragment set:html={svgBg} />
    </div>

    <!-- Badge -->
    {badge && (
      <span class="
        absolute top-4 right-4
        font-display italic text-[0.65rem] tracking-[0.1em]
        bg-amber-brand text-kiln-800
        px-3 py-1
      ">
        {badge}
      </span>
    )}
  </div>

  <!-- ── Body ─────────────────────────────────────────────── -->
  <div class="product-body p-7">

    <!-- Name -->
    <h3 class="font-display italic text-[1.55rem] text-crust-DEFAULT leading-tight tracking-[-0.01em]">
      {name}
    </h3>
    <p class="font-sans text-[0.78rem] text-smoke-light mt-1 tracking-[0.04em]">
      {nameJp}
    </p>

    <!-- Rule -->
    <div class="w-8 h-px bg-amber-brand my-4"></div>

    <!-- Description -->
    <p class="font-sans text-body-sm text-smoke-DEFAULT leading-[1.88]">
      {desc}
    </p>

    <!-- Price -->
    <p class="mt-5">
      <span class="font-display italic text-[1.2rem] text-amber-brand tracking-tight">
        {price}
      </span>
      {priceNote && (
        <span class="font-sans text-[0.75rem] text-smoke-light ml-2">
          {priceNote}
        </span>
      )}
    </p>

  </div>
</article>

<style>
  .product-card {
    background:  var(--c-cream);
    transition:  box-shadow 0.4s ease;
  }
  .product-card:hover {
    box-shadow: 0 16px 52px rgba(44, 26, 14, 0.16);
  }

  /* Ensure injected SVG fills its container */
  .product-img svg {
    width:   100%;
    height:  100%;
    display: block;
  }
</style>
