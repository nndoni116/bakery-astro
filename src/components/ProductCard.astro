---
// src/components/ProductCard.astro
// ─────────────────────────────────────────────────────────────
// A single bread product card.
// All data is injected by the parent <Products> via props,
// making it trivial to add, remove or reorder products.
// ─────────────────────────────────────────────────────────────
export interface Props {
  /** English display name, e.g. "Baguette" */
  name:    string;
  /** Japanese subtitle, e.g. "バゲット・トラディション" */
  nameJp:  string;
  /** Short prose description (Japanese) */
  desc:    string;
  /** Price string, e.g. "¥340" */
  price:   string;
  /** Optional badge text, e.g. "Signature" | "Popular" */
  badge?:  string;
  /** Inline SVG markup for the product illustration (full <svg> element) */
  svgIllustration: string;
  /** Stagger delay class, e.g. "" | "fade-in-delay-1" */
  delay?:  string;
}

const { name, nameJp, desc, price, badge, svgIllustration, delay = '' } = Astro.props;
---

<div class={`product-card fade-in ${delay}`}>
  <div class="product-img-wrap">
    <Fragment set:html={svgIllustration} />
    {badge && <span class="product-badge">{badge}</span>}
  </div>
  <div class="product-body">
    <p class="product-name">{name}</p>
    <p class="product-name-jp">{nameJp}</p>
    <div class="product-divider"></div>
    <p class="product-desc">{desc}</p>
    <p class="product-price">{price}</p>
  </div>
</div>

<style>
  /* ── Card shell ─────────────────────────────────────────── */
  .product-card {
    background:  var(--color-cream);
    overflow:    hidden;
    cursor:      pointer;
    transition:  box-shadow 0.4s;
  }
  .product-card:hover {
    box-shadow: 0 20px 60px rgba(44,26,14,0.18);
  }

  /* ── Illustration area ──────────────────────────────────── */
  .product-img-wrap {
    height:    260px;
    overflow:  hidden;
    position:  relative;
    background: var(--color-smoke);
  }
  /* Target the SVG injected by set:html */
  .product-img-wrap > svg {
    width:      100%;
    height:     100%;
    transition: transform 0.6s cubic-bezier(.22,1,.36,1), filter 0.4s;
  }
  .product-card:hover .product-img-wrap > svg {
    transform: scale(1.06);
    filter:    brightness(1.08);
  }

  /* ── Badge ──────────────────────────────────────────────── */
  .product-badge {
    position:       absolute;
    top: 16px; right: 16px;
    background:     var(--color-amber);
    color:          var(--color-crust);
    font-family:    var(--font-serif-en);
    font-size:      0.65rem;
    font-style:     italic;
    letter-spacing: 0.1em;
    padding:        4px 12px;
  }

  /* ── Body copy ──────────────────────────────────────────── */
  .product-body       { padding: 28px 28px 32px; }
  .product-name {
    font-family: var(--font-serif-en);
    font-size:   1.5rem;
    font-weight: 700;
    font-style:  italic;
    color:       var(--color-crust);
  }
  .product-name-jp {
    font-family:  var(--font-serif-jp);
    font-size:    0.85rem;
    color:        var(--color-ash);
    margin-top:   4px;
  }
  .product-divider {
    width:      32px;
    height:     1px;
    background: var(--color-amber);
    margin:     16px 0;
  }
  .product-desc {
    font-size:   0.82rem;
    color:       var(--color-smoke);
    line-height: 1.9;
  }
  .product-price {
    font-family: var(--font-serif-en);
    font-size:   1.1rem;
    font-weight: 700;
    color:       var(--color-amber);
    margin-top:  16px;
  }
</style>
