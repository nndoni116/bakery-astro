---
// src/pages/index.astro
// ─────────────────────────────────────────────────────────────
// Top page — imports BaseLayout and all section components,
// then composes them in order. Adding / reordering sections
// is as simple as moving a component import and its JSX tag.
// ─────────────────────────────────────────────────────────────
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero       from '../components/Hero.astro';
import Concept    from '../components/Concept.astro';
import Products   from '../components/Products.astro';
import Schedule   from '../components/Schedule.astro';
import Access     from '../components/Access.astro';
---

<BaseLayout
  title="Boulangerie Kura | ハード系パン専門店"
  description="自家製酵母と24時間発酵。窯から生まれる、本物のパン。仙台・一番町。"
>
  <Hero />
  <Concept />
  <Products />
  <Schedule />
  <Access />
</BaseLayout>
