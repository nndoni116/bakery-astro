---
// src/pages/index.astro
// ──────────────────────────────────────────────────────────────
// Top page (landing page).
// This file's only job is to declare the page metadata and
// assemble the section components in the correct order.
//
// To add a new section: import its component here and place
// the tag in the desired position inside <BaseLayout>.
// ──────────────────────────────────────────────────────────────
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero       from '../components/Hero.astro';
import Concept    from '../components/Concept.astro';
import News from "../components/News.astro"; // 1. インポートする
import Products   from '../components/Products.astro';
import Access     from '../components/Access.astro';
---

<BaseLayout>
  <Hero />
  <News />
  <Concept />
  <Products />
  <Access />
</BaseLayout>
